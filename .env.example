# ─────────────────────────────────────────────
#  HAWKEYE — .env.example
#  Copy to .env and fill in real values.
#  chmod 600 .env — never commit .env to git.
# ─────────────────────────────────────────────

# ── General ──────────────────────────────────
PUBLIC_BASE_URL=https://hawkeye.nineagents.in
ENVIRONMENT=development   # development | production
LOG_LEVEL=INFO

# ── Postgres ─────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hawkeye
POSTGRES_USER=hawkeye
POSTGRES_PASSWORD=changeme_postgres

# ── Redis ────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis

# ── Kafka ────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=hawkeye.events
KAFKA_GROUP_ID=hawkeye-consumer

# ── Neo4j ────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j

# ── MinIO ────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_BUCKET=hawkeye-artifacts

# ── Keycloak ─────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=hawkeye
KEYCLOAK_CLIENT_ID=hawkeye-backend
KEYCLOAK_CLIENT_SECRET=changeme_keycloak_secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_admin

# ── Anthropic ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Groq (fallback LLM) ──────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# ── MLflow ───────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=hawkeye-scoring

# ── Scoring ──────────────────────────────────
MODEL_M1_PATH=/app/artifacts/lgb_model_m1_full.txt
MODEL_M2_PATH=/app/artifacts/lgb_model_m2_full.txt
FEATURE_CONFIG_PATH=/app/artifacts/feature_config.json
FEATURE_STATS_PATH=/app/artifacts/feature_stats.json
SHAP_BACKGROUND_ROWS=200
SCORE_TRIGGER_EVERY_N_EVENTS=10
SCORE_TRIGGER_EVERY_N_SECONDS=60
ALERT_DEDUP_WINDOW_SECONDS=3600

# ── Replay ───────────────────────────────────
REPLAY_EVENTS_PATH=/app/data/synthetic_events.jsonl
REPLAY_DEFAULT_RATE=50        # events per second
REPLAY_MAX_RATE=5000

# ── Frontend (Vite build-time) ───────────────
VITE_KEYCLOAK_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=hawkeye
VITE_KEYCLOAK_CLIENT_ID=hawkeye-frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
FRONTEND_BASE_URL=http://localhost:8080

# ── Observability ────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy   # uncomment and fill to enable Sentry
SENTRY_DSN=
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana
